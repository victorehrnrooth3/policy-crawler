# Copy this file to `.env` for local development. Never commit `.env`.
# Each variable mirrors the secrets table in docs/03-tech-stack.md.

# Anthropic API key. Used by crawler/ranker, weekly discovery, weekly self-update.
ANTHROPIC_API_KEY=

# Neon Postgres connection string (POOLED, "-pooler" host). Used by webapp and scheduled jobs.
NEON_DATABASE_URL=

# Neon Postgres connection string (DIRECT, non-pooler). Used by local migration scripts only.
NEON_DATABASE_URL_DIRECT=

# Resend API key. Used by the daily digest job and failure-alert emails.
RESEND_API_KEY=

# Sender address for the digest, e.g. digest@policycrawler.dev.
DIGEST_FROM_EMAIL=

# Recipient address (my personal inbox).
DIGEST_TO_EMAIL=

# Public base URL of the deployed webapp, used to build vote-link URLs in emails.
WEBAPP_BASE_URL=

# HMAC key for signed vote / magic-link tokens. Generate >=32 random bytes (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`).
TOKEN_HMAC_SECRET=

# Cookie-signing key for the FastAPI webapp session.
SESSION_COOKIE_SECRET=

# Optional. Fine-grained GitHub PAT scoped to this repo, used by the weekly self-update job
# to open a PR with the proposed profile.yaml change.
GH_PAT_FOR_PROFILE_PR=
